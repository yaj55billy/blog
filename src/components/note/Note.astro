---
import { type CollectionEntry, render } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	note: CollectionEntry<"note">;
	isPreview?: boolean | undefined;
};

const { as: Tag = "div", note, isPreview = false } = Astro.props;
const { Content } = await render(note);
---

<article
	class:list={[isPreview && "relative isolate grid w-full rounded-lg bg-color-75 border border-color-200 px-4 md:px-8 py-4 md:py-6 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md"]}
	data-pagefind-body={isPreview ? false : true}
>
	<Tag
		class="flex items-end title"
		class:list={{ "text-base": isPreview }}
	>
		{
			isPreview ? (
				<a class="after:absolute after:inset-0 after:z-[1]" href={`/essays/${note.id}/`}>
					{note.data.title}
				</a>
			) : (
				<>{note.data.title}</>
			)
		}
	</Tag>
	<div
		class="flex items-center h-6 text-sm text-lighter"
		class:list={{ "mt-3": !isPreview, "mt-2": isPreview }}
	>
		<FormattedDate
			dateTimeOptions={{
				year: "numeric",
				month: "long",
				day: "2-digit",
			}}
			date={note.data.publishDate}
		/>
	</div>
	{!isPreview && <hr class="mt-4 border-color-200" />}
	{isPreview ? (
		note.data.description ? (
			<p class="mt-3 text-sm text-lighter line-clamp-3">{note.data.description}</p>
		) : (
			<div class="prose prose-sm prose-citrus mt-3 max-w-none [&>p:last-of-type]:mb-0 line-clamp-3 [&>blockquote]:line-clamp-3 [&>blockquote]:mb-0 [&>blockquote:not(:first-of-type)]:hidden">
				<Content />
			</div>
		)
	) : (
		<div class="prose prose-citrus mt-4 max-w-none [&>p:last-of-type]:mb-0">
			<Content />
		</div>
	)}
	{!isPreview && (
		<footer class="mt-10 pt-6 border-t border-color-200 flex items-center justify-between text-sm">
			<a
				class="citrus-link text-lighter hover:text-accent-base"
				href="/essays/"
			>
				← 返回記錄
			</a>
			<FormattedDate
				class="text-lighter"
				dateTimeOptions={{ year: "numeric", month: "long", day: "2-digit" }}
				date={note.data.publishDate}
			/>
		</footer>
	)}
</article>
