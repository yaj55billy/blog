---
import { type CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";
import { Icon } from "astro-icon/components";

// Posts
const MAX_POSTS = 3;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];
---

<PageLayout meta={{ title: "Home" }}>
	<!-- Hero Section -->
	<section class="mb-16">
		<div class="flex flex-col sm:flex-row-reverse gap-8 items-start">
			<!-- Avatar -->
			<img
				src="/images/logo.png"
				alt="圓臉助教"
				class="rounded-xl w-36 h-36 sm:w-48 sm:h-48 object-cover flex-shrink-0"
			/>

			<!-- Bio -->
			<div class="flex-1 min-w-0">
				<h1 class="title text-2xl mb-4">哈囉，我是圓臉助教</h1>
				<div class="space-y-3 leading-relaxed">
					<p>
						為什麼會開始寫文章跟錄製 Podcast？
					</p>
					<p>
            幾年前，發生了一些意外之後，身體開始產生疑難雜症，並在恢復的過程中，經歷了許多負面、懷疑、衝突的關卡；而在不斷的嘗試跟調整，以及家人朋友的支持後，我開始能理解從「負面事件去看待正面的意義」，如果沒有這樣的事件，我也沒有機會動搖那頑固的習氣，重新調整人生各個層面。
					</p>
					<p>
            隨著身體不斷好轉，我也開始更進一步地探索自己，例如：我是誰？有什麼特質？做什麼會覺得開心？而在這樣的探索之中，我也開始想把一些學習、體悟嘗試分享出來。
					</p>
          <p>
            預計分享：身心失衡、人生低谷之後的經驗、體悟與探索，以及一些書籍心得跟生活紀錄等。<br/>
            這裡沒有標準答案，只有往內在真實的旅程。希望我們可以一起討論、一起成長。
          </p>
          <div>
            我的特質跟創作底線：
            <ul class="list-disc mt-2 ml-6">
              <li><strong>急躁與完美主義的融合體</strong>：這個特質就像拿磚頭砸自己的腳，所以正在學習慢下來跟有意識降低完美主義的比例</li>
              <li><strong>吃速食的習慣</strong>：雖然調整飲食後已經比較少吃麥當勞，但我很喜歡在吃完漢堡後，將包裝紙折得很整齊（尤其是內用時）</li>
              <li><strong>創作底線</strong>：創作的文字、Podcast 不會出現帶有 AI 感的文字編排，我想在這些分享中，依然保持人味跟真實！</li>
            </ul>
          </div>
          
				</div>
				<!-- Social Links -->
				<div class="mt-6 flex items-center gap-4">
					<a
						href="https://www.instagram.com/billyji2024/"
						target="_blank"
						rel="noreferrer"
						class="flex items-center gap-1.5 text-sm text-lighter border border-color-200 rounded-full px-3 py-1.5 hover:text-accent-two hover:border-accent-two transition-colors"
						aria-label="Instagram"
					>
						<Icon class="h-5 w-5" name="mdi:instagram" />
						<span>Instagram</span>
					</a>
					<a
						href="https://podcasts.apple.com/"
						target="_blank"
						rel="noreferrer"
						class="flex items-center gap-1.5 text-sm text-lighter border border-color-200 rounded-full px-3 py-1.5 hover:text-accent-two hover:border-accent-two transition-colors"
						aria-label="Podcast"
					>
						<Icon class="h-5 w-5" name="mdi:podcast" />
						<span>Podcast</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Posts Section -->
	<section aria-label="Blog post list">
		<h2 class="title mb-4 text-xl flex items-center justify-between">
			<a class="hover:text-accent-two transition-colors" href="/posts/">文章</a>
			<a class="text-sm font-normal text-lighter hover:text-accent-base transition-colors" href="/posts/">
				查看全部 →
			</a>
		</h2>
		<ul class="space-y-4" role="list">
			{
				allPostsByDate.map((p) => (
					<li class="relative bg-color-75 rounded-lg px-4 md:px-8 py-3 md:py-4 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
						<PostPreview post={p} withDesc={true} />
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
